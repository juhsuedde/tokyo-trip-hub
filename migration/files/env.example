# backend/.env.example
# Copy to .env and fill in your values

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/tokyotrip

# ── Redis (Bull queues) ───────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
EXPORTS_DIR=./exports
SERVER_URL=http://localhost:3001

# ── AI Provider Selection ─────────────────────────────────────────────────────
# Set MOCK_AI=true for local development without any API keys.
# For real providers, set at least one key per task type:
#
#   Transcription (audio): GROQ_API_KEY preferred, OPENAI_API_KEY as fallback
#   Vision (images):       OPENROUTER_API_KEY preferred, OPENAI_API_KEY as fallback
#
# Priority order (first available wins):
#   transcribe : Groq → OpenAI
#   vision     : OpenRouter → OpenAI

MOCK_AI=true

# OpenAI — production fallback for both tasks
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Groq — fast & cheap Whisper transcription (whisper-large-v3)
# Free tier: ~28 hours/day · https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# OpenRouter — free vision models (nova-2-lite, pixtral-12b, qwen2.5-vl)
# Free tier available · https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
