DATABASE_URL="postgresql://postgres:postgres@postgres:5432/tokyotrip?schema=public"
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OPENAI_API_KEY=sk-your-key-here
BASE_URL=http://backend:3001
PORT=3001
UPLOAD_DIR=./uploads
MOCK_AI=true
JWT_SECRET=your-secret-key-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30

# Storage
STORAGE_TYPE=local
UPLOAD_DIR=./uploads

# S3 (when STORAGE_TYPE=s3)
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Cloudinary (when STORAGE_TYPE=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (for password reset)
EMAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@tokyotriphub.com
APP_BASE_URL=http://localhost:5173

# Data retention (FREE tier)
DATA_RETENTION_ARCHIVE_DAYS=30
DATA_RETENTION_DELETE_DAYS=90
DATA_RETENTION_WARN_DAYS=7